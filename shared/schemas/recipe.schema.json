{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recipeforge.local/schemas/recipe.schema.json",
  "title": "Recipe",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "scope",
    "title",
    "status",
    "created_at",
    "updated_at",
    "equipment",
    "ingredients",
    "steps"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "format": "uuid" },
    "scope": { "type": "string", "enum": ["bundled", "local"] },
    "bundled_content_version": { "type": ["string", "null"] },
    "bundle_export_eligible": { "type": "boolean", "default": false },
    "export_bundle_recipe_id": { "type": ["string", "null"], "format": "uuid" },
    "export_bundle_recipe_version": { "type": "integer", "minimum": 1, "default": 1 },
    "origin_bundled_recipe_id": { "type": ["string", "null"], "format": "uuid" },
    "origin_bundled_recipe_version": { "type": ["integer", "null"], "minimum": 1 },
    "is_forked_from_bundled": { "type": "boolean", "default": false },
    "imported_from_package_id": { "type": ["string", "null"] },
    "imported_from_recipe_id": { "type": ["string", "null"], "format": "uuid" },
    "imported_at": { "type": ["string", "null"], "format": "date-time" },
    "import_source_label": { "type": ["string", "null"] },
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": ["string", "null"] },
    "author": { "type": ["string", "null"] },
    "source_name": { "type": ["string", "null"] },
    "source_url": { "type": ["string", "null"], "format": "uri-reference" },
    "tags": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "category": { "type": ["string", "null"] },
    "difficulty": { "type": ["string", "null"], "enum": ["easy", "medium", "hard", null] },
    "servings": { "type": ["number", "null"], "minimum": 0 },
    "prep_minutes": { "type": ["integer", "null"], "minimum": 0 },
    "cook_minutes": { "type": ["integer", "null"], "minimum": 0 },
    "total_minutes": { "type": ["integer", "null"], "minimum": 0 },
    "notes": { "type": ["string", "null"] },
    "cover_media_id": { "type": ["string", "null"], "format": "uuid" },
    "display_settings": { "type": "object", "additionalProperties": true },
    "status": { "type": "string", "enum": ["draft", "published", "archived"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "deleted_at": { "type": ["string", "null"], "format": "date-time" },
    "equipment": {
      "type": "array",
      "items": { "$ref": "#/$defs/equipmentItem" }
    },
    "ingredients": {
      "type": "array",
      "items": { "$ref": "#/$defs/ingredientItem" }
    },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/$defs/stepItem" }
    },
    "step_links": {
      "type": "array",
      "items": { "$ref": "#/$defs/stepLink" },
      "default": []
    }
  },
  "additionalProperties": false,
  "$defs": {
    "equipmentItem": {
      "type": "object",
      "required": ["id", "name", "is_required", "display_order"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "why_used": { "type": ["string", "null"] },
        "is_required": { "type": "boolean" },
        "notes": { "type": ["string", "null"] },
        "affiliate_url": { "type": ["string", "null"], "format": "uri-reference" },
        "alternate_equipment_text": { "type": ["string", "null"] },
        "media_id": { "type": ["string", "null"], "format": "uuid" },
        "display_order": { "type": "integer", "minimum": 0 },
        "global_equipment_id": { "type": ["string", "null"], "format": "uuid" }
      },
      "additionalProperties": false
    },
    "ingredientItem": {
      "type": "object",
      "required": ["id", "raw_text", "is_optional", "display_order"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "raw_text": { "type": "string", "minLength": 1 },
        "quantity_value": { "type": ["number", "null"], "minimum": 0 },
        "quantity_text": { "type": ["string", "null"] },
        "unit": { "type": ["string", "null"] },
        "ingredient_name": { "type": ["string", "null"] },
        "preparation_notes": { "type": ["string", "null"] },
        "substitutions": { "type": ["string", "null"] },
        "affiliate_url": { "type": ["string", "null"], "format": "uri-reference" },
        "recommended_product": { "type": ["string", "null"] },
        "media_id": { "type": ["string", "null"], "format": "uuid" },
        "is_optional": { "type": "boolean" },
        "display_order": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "stepTimer": {
      "type": "object",
      "required": ["id", "label", "duration_seconds", "auto_start"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "label": { "type": "string", "minLength": 1 },
        "duration_seconds": { "type": "integer", "minimum": 1 },
        "auto_start": { "type": "boolean" },
        "alert_sound_key": { "type": ["string", "null"] },
        "alert_vibrate": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    },
    "stepItem": {
      "type": "object",
      "required": ["id", "body_text", "display_order", "step_type", "timers"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "title": { "type": ["string", "null"] },
        "body_text": { "type": "string", "minLength": 1 },
        "display_order": { "type": "integer", "minimum": 0 },
        "step_type": { "type": "string", "enum": ["instruction", "note", "section_break"] },
        "estimated_seconds": { "type": ["integer", "null"], "minimum": 0 },
        "media_id": { "type": ["string", "null"], "format": "uuid" },
        "timers": { "type": "array", "items": { "$ref": "#/$defs/stepTimer" } }
      },
      "additionalProperties": false
    },
    "stepLink": {
      "type": "object",
      "required": ["id", "step_id", "target_type", "target_id", "token_key", "label_snapshot"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "step_id": { "type": "string", "format": "uuid" },
        "target_type": { "type": "string", "enum": ["ingredient", "equipment"] },
        "target_id": { "type": "string", "format": "uuid" },
        "token_key": { "type": "string", "minLength": 1 },
        "label_snapshot": { "type": "string", "minLength": 1 },
        "label_override": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  }
}
