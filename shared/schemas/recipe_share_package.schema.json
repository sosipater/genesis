{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recipeforge.local/schemas/recipe_share_package.schema.json",
  "title": "RecipeSharePackage",
  "type": "object",
  "required": [
    "share_format_version",
    "package_id",
    "exported_at_utc",
    "source_app",
    "media_included",
    "recipes"
  ],
  "properties": {
    "share_format_version": { "type": "integer", "minimum": 1 },
    "package_id": { "type": "string", "minLength": 1 },
    "exported_at_utc": { "type": "string", "format": "date-time" },
    "source_app": { "type": "string", "minLength": 1 },
    "media_included": { "type": "boolean" },
    "recipes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" }
    }
  },
  "additionalProperties": false
}
